{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/silo-ai/silo/schemas/report-put.schema.json",
  "title": "Silo report definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["slug", "title", "markdown", "queries"],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "markdown": {
      "type": "string",
      "minLength": 1
    },
    "queries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "sql"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_-]*$"
          },
          "sql": {
            "type": "string",
            "minLength": 1
          },
          "empty_markdown": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
